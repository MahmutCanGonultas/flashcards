# Postgres connection string. Neon, Supabase or a local postgres all work.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Used to sign login tokens. Any long random string; keep it out of git.
# Generate one with: openssl rand -base64 32
JWT_SECRET=change-me

# Where the web client is served from. Comma-separated to allow more than one.
# Only needed in production; defaults to the Vite dev server.
CORS_ORIGIN=http://localhost:5173

# Hosting platforms set this themselves. Leave it unset locally.
# PORT=3000
